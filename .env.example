# Copy this file to .env and fill in your values before running `docker compose up -d`

# ── User / Group IDs ─────────────────────────────────────────────────────────
# Run `id` in your terminal to find your uid and gid.
# All linuxserver.io containers use these to avoid permission issues.
PUID=1000
PGID=1000

# ── Timezone ──────────────────────────────────────────────────────────────────
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/London

# ── VPN (Gluetun + ProtonVPN WireGuard) ──────────────────────────────────────
# Generate a WireGuard config in your ProtonVPN account dashboard,
# then paste the PrivateKey value here.
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key_here

# Comma-separated list of countries for the VPN server selection.
VPN_SERVER_COUNTRIES=Netherlands

# ── Pi-hole ───────────────────────────────────────────────────────────────────
# Admin password for the Pi-hole web UI (http://<host>:8053/admin)
PIHOLE_PASSWORD=changeme
